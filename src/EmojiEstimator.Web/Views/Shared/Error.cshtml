@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="page-shell">
    <div class="rounded-3xl border border-rose-500/20 bg-rose-500/10 p-8 shadow-glow sm:p-10">
        <h1 class="text-3xl font-semibold tracking-tight text-rose-100">Error.</h1>
        <h2 class="mt-3 text-lg text-rose-200">An error occurred while processing your request.</h2>

        @if (Model.ShowRequestId)
        {
            <p class="mt-4 text-sm text-rose-100/90">
                <strong>Request ID:</strong> <code class="rounded bg-slate-950/60 px-2 py-1 text-xs text-slate-100">@Model.RequestId</code>
            </p>
        }
    </div>

    <div class="page-card">
        <h3 class="text-xl font-semibold tracking-tight text-white">Development Mode</h3>
        <p class="mt-4 text-base leading-7 text-slate-300">
            Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
        </p>
        <p class="mt-4 text-base leading-7 text-slate-300">
            <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
            It can result in displaying sensitive information from exceptions to end users.
            For local debugging, enable the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong>
            and restarting the app.
        </p>
    </div>
</section>
